    r.id_medico AS crm,
    r.id_paciente,
    p.nome AS paciente,
    r.descricao,
    r.status,
    r.prioridade
FROM requerimentos r
JOIN paciente p 
    ON p.id_paciente = r.id_paciente
WHERE r.id_medico = 101
ORDER BY 
    CASE 
        WHEN r.prioridade = 'critico' THEN 1
        WHEN r.prioridade = 'urgente' THEN 2
